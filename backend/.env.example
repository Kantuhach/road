# Backend environment — copy this file to `.env` in this folder before running the server or seed.
#
#   Windows (PowerShell):  Copy-Item .env.example .env
#   Mac/Linux:             cp .env.example .env
#
# Then run from this folder:
#   npm install
#   npm run seed

MONGODB_URI=mongodb://localhost:27017/road-accident-system
JWT_SECRET=your-secret-key-change-in-production
PORT=8080
