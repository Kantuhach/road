# Copy to .env and paste your key from Google Cloud Console (Maps JavaScript API + Directions API).
VITE_GOOGLE_MAPS_API_KEY=

# Optional: backend origin when the SPA is NOT proxied to Node (production CDN/static hosting).
# Leave unset during local dev — Vite proxies /api to localhost:8080.
# Example: VITE_API_BASE_URL=https://api.yoursite.com
VITE_API_BASE_URL=
